# Axiom — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# WARNING: Never commit broker credentials or API keys.

# LLM
OPENAI_API_KEY=

# Market Data — ALL market data comes from Unusual Whales
UNUSUAL_WHALES_API_KEY=

# Interactive Brokers
IBKR_HOST=127.0.0.1
IBKR_PORT=7497        # 7497 = paper, 7496 = live
IBKR_CLIENT_ID=1

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/axiom
REDIS_URL=redis://localhost:6379

# Trading settings
TRADING_MODE=paper    # paper | live — START WITH PAPER
STARTING_CAPITAL=100000
MAX_DRAWDOWN_PCT=0.10
MAX_DAILY_LOSS_PCT=0.03

PORT=3102
NODE_ENV=development
